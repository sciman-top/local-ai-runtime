  "measurement_rules": {
    "active_and_passive_time": "active_human_minutes and passive_wait_minutes are required separate fields. Neither may be inferred from the other.",
    "token_and_cost": "token_and_cost records availability, source, value, and currency. unavailable is not zero.",
    "conflict_and_rework": "Record every conflict category, retry, rework loop, and terminal disposition.",
    "safety_gate_evidence": "Every gate receipt includes command or gate_na reason, exit code when executed, and evidence locator.",
    "external_effects": "An unknown or unowned external effect produces stopped or inconclusive status and blocks a promotion claim.",
    "downstream_sampling": "The runtime does not push, read remote CI, merge, reject, or synthesize downstream outcomes. An operator may attach secret-safe external evidence locators later."
  },
  "terminal_decision_rules": {
    "quality_security_or_evidence_regression": "Efficiency gains remain reportable but are invalid for promotion.",
    "semantic_change": "narrow_profile_or_adapter_candidate and supersede_required require a v3.24 successor; v3.23 may not be rewritten.",
    "preserve": "preserve_v3_23_semantics is non-normative and only releases P0A closure."
  }

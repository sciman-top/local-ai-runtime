{
  "catalog_id": "GitConfigPolicy.v1",
  "schema_version": 1,
  "default_action": "deny",
  "key_comparison": "ascii_case_insensitive_after_git_name_validation",
  "classification_order": [
    "deny_exact",
    "deny_prefix",
    "allow_safe_value",
    "allow_name_only",
    "default_deny"
  ],
  "duplicate_singleton_result": "reject",
  "invalid_value_result": "reject",
  "value_read_policy": {
    "allow_safe_value": "read_then_validate_bounded_value",
    "allow_name_only": "never_read_value",
    "deny": "never_read_value"
  },
  "allow_safe_value": [
    {"key": "core.repositoryformatversion", "multiplicity": "singleton", "validator": {"kind": "integer_enum", "allowed": [0]}},
    {"key": "extensions.objectformat", "multiplicity": "singleton", "validator": {"kind": "string_enum", "allowed": ["sha1"]}},
    {"key": "extensions.refstorage", "multiplicity": "singleton", "validator": {"kind": "string_enum", "allowed": ["files"]}},
    {"key": "extensions.worktreeconfig", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.bare", "multiplicity": "singleton", "validator": {"kind": "boolean_enum", "allowed": [false]}},
    {"key": "core.filemode", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.logallrefupdates", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.symlinks", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.ignorecase", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.protectntfs", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.protecthfs", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.longpaths", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.autocrlf", "multiplicity": "singleton", "validator": {"kind": "string_enum", "allowed": ["false", "input", "true"]}},
    {"key": "core.eol", "multiplicity": "singleton", "validator": {"kind": "string_enum", "allowed": ["native", "lf", "crlf"]}},
    {"key": "core.safecrlf", "multiplicity": "singleton", "validator": {"kind": "string_enum", "allowed": ["false", "warn", "true"]}},
    {"key": "core.precomposeunicode", "multiplicity": "singleton", "validator": {"kind": "boolean"}},
    {"key": "core.sparsecheckout", "multiplicity": "singleton", "validator": {"kind": "boolean_enum", "allowed": [false]}},
    {"key": "core.sparsecheckoutcone", "multiplicity": "singleton", "validator": {"kind": "boolean_enum", "allowed": [false]}},
    {"key": "index.sparse", "multiplicity": "singleton", "validator": {"kind": "boolean_enum", "allowed": [false]}}
  ],
  "allow_name_only": [
    {"pattern": "remote.*.url", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"},
    {"pattern": "remote.*.pushurl", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"},
    {"pattern": "remote.*.fetch", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"},
    {"pattern": "remote.*.push", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"},
    {"pattern": "branch.*.remote", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"},
    {"pattern": "branch.*.merge", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"},
    {"pattern": "lfs.url", "pattern_kind": "exact", "multiplicity": "singleton"},
    {"pattern": "lfs.pushurl", "pattern_kind": "exact", "multiplicity": "singleton"},
    {"pattern": "lfs.*.access", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"},
    {"pattern": "remote.*.lfsurl", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"},
    {"pattern": "remote.*.lfspushurl", "pattern_kind": "one_segment_wildcard", "multiplicity": "multiple"}
  ],
  "deny_exact": [
    "core.hookspath",
    "core.excludesfile",
    "core.attributesfile",
    "core.fsmonitor",
    "core.editor",
    "core.pager",
    "core.askpass",
    "core.sshcommand",
    "core.worktree",
    "core.alternaterefscommand",
    "commit.gpgsign",
    "tag.gpgsign",
    "gpg.program",
    "sequence.editor"
  ],
  "deny_prefixes": [
    "include.",
    "includeif.",
    "credential.",
    "http.",
    "filter.",
    "diff.",
    "merge.",
    "hooks.",
    "fsmonitor.",
    "gpg.",
    "user.",
    "url.",
    "protocol.",
    "submodule.",
    "alias.",
    "pager.",
    "ssh.",
    "browser.",
    "interactive.",
    "safe.",
    "mailmap."
  ],
  "required_audit_surfaces": [
    ".git/info/attributes",
    ".git/info/exclude",
    "default_hooks",
    "config.worktree",
    "objects/info/alternates",
    "refs/replace",
    "info/grafts",
    "base:.gitattributes",
    "base:.gitmodules",
    "base:.lfsconfig",
    "base:gitlink_entries",
    "touched_path_attributes",
    "protected_path_mode_oid"
  ]
}

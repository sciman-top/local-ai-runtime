{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-ai-runtime.invalid/schemas/FirstRunExperience.v1.schema.json",
  "title": "FirstRunExperiencePolicy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "policy_version",
    "baseline_id",
    "journey",
    "output_contract",
    "mutation_contract",
    "exit_codes",
    "terminal_outcome"
  ],
  "properties": {
    "policy_id": {"const": "first_run_cli_to_reviewable_commit"},
    "policy_version": {"const": "FirstRunExperiencePolicy.v1"},
    "baseline_id": {"const": "local-ai-runtime-0.2-v3.24"},
    "journey": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {"$ref": "#/$defs/journey_step"}
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "machine_format",
        "machine_unknown_field_policy",
        "human_renderer",
        "human_source",
        "forbidden_sources"
      ],
      "properties": {
        "machine_format": {"const": "stable_json"},
        "machine_unknown_field_policy": {"const": "fail_closed"},
        "human_renderer": {"const": "OperatorPresentationCatalog.v1"},
        "human_source": {"const": "public_machine_state_and_reason_codes_only"},
        "forbidden_sources": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": ["raw_model_output", "raw_tool_output", "secret_derived_metadata"]
          }
        }
      }
    },
    "mutation_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_required",
        "required_preview_fields",
        "challenge_policy",
        "read_only_approval_policy"
      ],
      "properties": {
        "preview_required": {"const": true},
        "required_preview_fields": {
          "const": [
            "effect_summary",
            "authority",
            "expected_generation",
            "rollback_entrypoint",
            "challenge_required"
          ]
        },
        "challenge_policy": {"const": "catalog_and_authority_driven"},
        "read_only_approval_policy": {"const": "never"}
      }
    },
    "exit_codes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success", "policy_or_input_error", "temporary_unavailable"],
      "properties": {
        "success": {"const": 0},
        "policy_or_input_error": {"const": 2},
        "temporary_unavailable": {"const": 3}
      }
    },
    "terminal_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "delivery", "forbidden_delivery"],
      "properties": {
        "result": {"const": "reviewable_local_commit"},
        "delivery": {"const": ["deterministic_local_commit", "runtime_owned_task_ref"]},
        "forbidden_delivery": {"const": ["merge", "push", "pull_request", "deployment"]}
      }
    }
  },
  "$defs": {
    "public_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,62}$"},
    "public_field": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,62}$"},
    "journey_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "order",
        "command",
        "kind",
        "authority",
        "input_fields",
        "human_output_fields",
        "json_output_fields",
        "success_exit_code",
        "failure_exit_codes",
        "evidence_locator",
        "rollback",
        "next_step_ids"
      ],
      "properties": {
        "step_id": {"$ref": "#/$defs/public_id"},
        "order": {"type": "integer", "minimum": 1, "maximum": 10},
        "command": {"type": "string", "minLength": 3, "maxLength": 256},
        "kind": {"enum": ["read_only", "mutation"]},
        "authority": {"enum": ["none", "operator_action", "reusable_authorization"]},
        "input_fields": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/public_field"}
        },
        "human_output_fields": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/public_field"}
        },
        "json_output_fields": {
          "type": "array",
          "minItems": 1,
          "maxItems": 24,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/public_field"}
        },
        "success_exit_code": {"const": 0},
        "failure_exit_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": [2, 3]}
        },
        "evidence_locator": {"$ref": "#/$defs/public_field"},
        "rollback": {"type": "string", "minLength": 3, "maxLength": 128},
        "next_step_ids": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/public_id"}
        }
      }
    }
  }
}

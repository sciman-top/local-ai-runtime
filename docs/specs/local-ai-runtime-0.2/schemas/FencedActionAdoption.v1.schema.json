{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-ai-runtime.invalid/schemas/FencedActionAdoption.v1.schema.json",
  "title": "FencedActionAdoption.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "action_id",
    "prior_head_kind",
    "prior_head_hash",
    "prior_fence",
    "new_fence",
    "takeover_proof_hash",
    "effect_spec_hash",
    "postcondition_verifier_id",
    "created_at_utc",
    "inherited_authority_kind",
    "inherited_authority_id",
    "inherited_authority_sha256",
    "adoption_hash"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "action_id": {"$ref": "#/$defs/public_id"},
    "prior_head_kind": {"enum": ["intent", "adoption"]},
    "prior_head_hash": {"$ref": "#/$defs/sha256"},
    "prior_fence": {"type": "integer", "minimum": 1},
    "new_fence": {"type": "integer", "minimum": 2},
    "takeover_proof_hash": {"$ref": "#/$defs/sha256"},
    "effect_spec_hash": {"$ref": "#/$defs/sha256"},
    "postcondition_verifier_id": {"$ref": "#/$defs/public_id"},
    "created_at_utc": {"$ref": "#/$defs/utc_timestamp"},
    "inherited_authority_kind": {"enum": ["authorization_execution_grant", "safety_only_execution_record"]},
    "inherited_authority_id": {"$ref": "#/$defs/public_id"},
    "inherited_authority_sha256": {"$ref": "#/$defs/sha256"},
    "adoption_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "public_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,62}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utc_timestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"}
  },
  "x-local-ai-runtime-adoption-hash": {
    "domain": "local-ai-runtime/FencedActionAdoption/v1",
    "hash": "lowercase_sha256_of_canonical_envelope_excluding_adoption_hash"
  }
}

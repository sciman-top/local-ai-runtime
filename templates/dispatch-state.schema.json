{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DispatchState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "task_id",
    "agent_role",
    "model_policy",
    "repo_root",
    "target_repo",
    "branch_name",
    "worktree_path",
    "allowed_paths",
    "forbidden_paths",
    "source_ref",
    "lease_owner",
    "started_at",
    "updated_at",
    "heartbeat_at",
    "stale_after",
    "execution_lane",
    "worker_profile",
    "status",
    "status_reason",
    "next_action",
    "cleanup_status",
    "cleanup_owner"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "agent_role": {
      "enum": [
        "master",
        "explorer",
        "worker",
        "spec_reviewer",
        "quality_reviewer",
        "closeout"
      ]
    },
    "model_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "reasoning_effort"
      ],
      "properties": {
        "model": {
          "type": "string"
        },
        "reasoning_effort": {
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ]
        },
        "fallback_model": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "repo_root": {
      "type": "string"
    },
    "target_repo": {
      "type": "string"
    },
    "branch_name": {
      "type": "string"
    },
    "worktree_path": {
      "type": "string"
    },
    "workspace_root": {
      "type": "string"
    },
    "route_reason": {
      "type": "string"
    },
    "orchestration_decision_ref": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ref": {
      "type": "string"
    },
    "lease_owner": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "attempt": {
      "type": "integer"
    },
    "updated_at": {
      "type": "string"
    },
    "heartbeat_at": {
      "type": "string"
    },
    "stale_after": {
      "type": "string"
    },
    "execution_lane": {
      "enum": [
        "host_local",
        "remote_non_gui",
        "vm_gui"
      ]
    },
    "resume_point": {
      "enum": [
        "task_intake",
        "worker_execution",
        "verification",
        "handoff",
        "cleanup"
      ]
    },
    "retry_rewind": {
      "enum": [
        "task_intake",
        "worker_execution",
        "verification",
        "handoff",
        "cleanup"
      ]
    },
    "review_disposition": {
      "enum": [
        "approve",
        "revise",
        "reject"
      ]
    },
    "review_disposition_at": {
      "type": "string"
    },
    "worker_profile": {
      "type": "string"
    },
    "status": {
      "enum": [
        "queued",
        "running",
        "input_required",
        "waiting_handoff",
        "needs_review",
        "completed",
        "failed",
        "cancelled",
        "stale",
        "resumed"
      ]
    },
    "status_reason": {
      "type": "string"
    },
    "next_action": {
      "type": "string"
    },
    "cleanup_status": {
      "enum": [
        "deferred",
        "inline_only",
        "cleaned",
        "cleanup_failed"
      ]
    },
    "cleanup_owner": {
      "type": "string"
    },
    "last_result_ref": {
      "type": "string"
    },
    "verification_summary_ref": {
      "type": "string"
    },
    "evidence_index_ref": {
      "type": "string"
    },
    "planner_result_ref": {
      "type": "string"
    },
    "handoff_receipt_ref": {
      "type": "string"
    },
    "review_result_ref": {
      "type": "string"
    },
    "closeout_bundle_ref": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

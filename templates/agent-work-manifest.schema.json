{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentWorkManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "repo_root",
    "objective",
    "model_policy",
    "truth_sources",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "agent_work_manifest.v1"
    },
    "run_id": {
      "type": "string"
    },
    "repo_root": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "model_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "reasoning_effort"
      ],
      "properties": {
        "model": {
          "type": "string"
        },
        "reasoning_effort": {
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ]
        },
        "fallback_model": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "orchestration_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "mode_preference",
        "max_concurrent_subagents",
        "max_total_subagents",
        "max_tree_depth",
        "write_conflict_policy",
        "stop_policy"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "mode_preference": {
          "enum": ["auto", "single_agent", "multi_agent"]
        },
        "max_concurrent_subagents": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "max_total_subagents": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "max_tree_depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "write_conflict_policy": {
          "enum": ["serialize", "reject"]
        },
        "stop_policy": {
          "enum": ["stop_on_scope_or_contract_conflict", "finish_independent_workstreams"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "max_concurrent_subagents": {"const": 0}
            }
          },
          "then": {
            "properties": {
              "max_total_subagents": {"const": 0},
              "max_tree_depth": {"const": 0}
            }
          }
        },
        {
          "if": {
            "properties": {
              "max_concurrent_subagents": {"minimum": 1}
            }
          },
          "then": {
            "properties": {
              "max_total_subagents": {"minimum": 1},
              "max_tree_depth": {"const": 1}
            }
          }
        }
      ]
    },
    "truth_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "global_forbidden_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evaluation_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experiment_id", "variant", "repeat_index"],
      "properties": {
        "experiment_id": {"type": "string", "minLength": 1},
        "variant": {"enum": ["baseline", "candidate"]},
        "repeat_index": {"type": "integer", "minimum": 1},
        "baseline_run_id": {"type": ["string", "null"]}
      },
      "allOf": [
        {
          "if": {"properties": {"variant": {"const": "candidate"}}},
          "then": {"required": ["baseline_run_id"]}
        }
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "title",
          "kind",
          "goal",
          "target_repo",
          "base_branch",
          "branch_name",
          "worktree_path",
          "read_set",
          "write_set",
          "allowed_paths",
          "forbidden_paths",
          "write_access",
          "risk_level",
          "merge_policy",
          "execution_lane",
          "requires_network",
          "requires_gui",
          "depends_on",
          "artifacts_out",
          "handoff_policy",
          "verification_commands",
          "done_when"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "explore",
              "implement",
              "review",
              "docs_sync",
              "closeout"
            ]
          },
          "intent": {
            "enum": [
              "general",
              "bugfix",
              "feature",
              "refactor",
              "research",
              "docs",
              "review",
              "migration",
              "operations"
            ]
          },
          "goal": {
            "type": "string"
          },
          "target_repo": {
            "type": "string"
          },
          "base_branch": {
            "type": "string"
          },
          "branch_name": {
            "type": "string"
          },
          "worktree_path": {
            "type": "string"
          },
          "read_set": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "write_set": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "write_access": {
            "type": "boolean"
          },
          "risk_level": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "merge_policy": {
            "enum": [
              "draft_pr_only",
              "manual_merge_only",
              "never_merge"
            ]
          },
          "execution_lane": {
            "enum": [
              "host_local",
              "remote_non_gui",
              "vm_gui"
            ]
          },
          "requires_network": {
            "type": "boolean"
          },
          "requires_gui": {
            "type": "boolean"
          },
          "user_forced_planner": {
            "const": true
          },
          "user_forced_review": {
            "const": true
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artifacts_out": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "handoff_policy": {
            "enum": [
              "none",
              "handoff_on_risk",
              "handoff_before_merge",
              "handoff_always"
            ]
          },
          "verification_commands": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "build",
              "test",
              "lint",
              "typecheck",
              "contract",
              "hotspot"
            ],
            "properties": {
              "build": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "test": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "lint": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "typecheck": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "contract": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "hotspot": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "done_when": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "worker_profile": {
            "type": "string"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrchestrationExecution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "orchestration_decision_ref",
    "run_id",
    "policy_version",
    "profile",
    "selected_mode",
    "status",
    "worker_execution_attempted",
    "result_count",
    "status_counts",
    "parallel_wave_count",
    "serial_wave_count",
    "skipped_task_ids",
    "wall_time_ms",
    "results",
    "default_entrypoint_changed",
    "active_queue_changed",
    "live_accepted"
  ],
  "properties": {
    "schema_version": {"const": "orchestration_execution.v1"},
    "decision_id": {"type": "string", "minLength": 1},
    "orchestration_decision_ref": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "policy_version": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "minLength": 1},
    "selected_mode": {"enum": ["single_agent", "multi_agent"]},
    "status": {"enum": ["completed", "partial", "blocked"]},
    "worker_execution_attempted": {"type": "boolean"},
    "result_count": {"type": "integer", "minimum": 0},
    "status_counts": {"type": "object"},
    "parallel_wave_count": {"type": "integer", "minimum": 0},
    "serial_wave_count": {"type": "integer", "minimum": 0},
    "skipped_task_ids": {"type": "array", "items": {"type": "string"}},
    "wall_time_ms": {"type": "integer", "minimum": 0},
    "results": {"type": "array", "items": {"type": "object"}},
    "default_entrypoint_changed": {"const": false},
    "active_queue_changed": {"const": false},
    "live_accepted": {"const": false}
  }
}
